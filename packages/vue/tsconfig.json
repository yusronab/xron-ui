{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": false,

    "jsx": "preserve",

    "skipLibCheck": true,
    "esModuleInterop": true,

    "lib": ["ESNext", "DOM"],

    "types": ["vue"]
  },

  "include": ["src", "env.d.ts"],

  "exclude": ["dist", "node_modules"]
}
