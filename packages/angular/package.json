{
  "name": "@xron-ui/angular",
  "version": "0.0.2",
  "description": "Angular Component Library",
  "author": "xron-labs",
  "license": "MIT",
  "homepage": "https://yusronab.github.io/xron-ui/angular",
  "repository": {
    "type": "git",
    "url": "https://github.com/yusronab/xron-ui.git",
    "directory": "packages/angular"
  },
  "private": false,
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "angular",
    "angular-components",
    "component-library",
    "ui",
    "design-system",
    "tailwindcss",
    "typescript",
    "frontend",
    "xron-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/xron-ui-angular.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json && pnpm build:css",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@angular/animations": "^20.1.8",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.3.26",
    "@angular/platform-browser": "^20.3.26"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/compiler": "^20.3.26",
    "@angular/compiler-cli": "^20.3.26",
    "@tailwindcss/cli": "^4.3.2",
    "ng-packagr": "^20.3.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2"
  }
}
