{
  "name": "@xron-ui/react",
  "version": "0.0.9",
  "description": "React Component Library",
  "author": "xron-labs",
  "license": "MIT",
  "homepage": "https://yusronab.github.io/xron-ui/react",
  "repository": {
    "type": "git",
    "url": "https://github.com/yusronab/xron-ui.git",
    "directory": "packages/react"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "react",
    "react-components",
    "component-library",
    "ui",
    "design-system",
    "tailwindcss",
    "typescript",
    "headless",
    "frontend",
    "xron-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && pnpm build:css",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
