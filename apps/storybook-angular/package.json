{
  "name": "storybook-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run storybook-angular:storybook",
    "build-storybook": "ng run storybook-angular:build-storybook"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^20.3.26",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.26",
    "@angular/forms": "^20.3.26",
    "@angular/platform-browser": "^20.3.26",
    "@angular/router": "^20.3.0",
    "@xron-ui/angular": "workspace:*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@angular-devkit/architect": "^0.2003.0",
    "@angular-devkit/build-angular": "^20.3.0",
    "@angular-devkit/core": "^20.3.0",
    "@angular/animations": "^20.3.26",
    "@angular/build": "^20.3.32",
    "@angular/cli": "^20.3.32",
    "@angular/compiler-cli": "^20.3.0",
    "@storybook/angular-vite": "^10.5.3",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "storybook": "^10.5.3",
    "typescript": "~5.9.2",
    "vite": "^8.1.5"
  }
}
