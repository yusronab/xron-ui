{
  "name": "xron-ui",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "build:react": "pnpm --filter react build",
    "storybook:react": "pnpm --filter storybook storybook",
    "build-storybook:react": "pnpm --filter storybook build-storybook",
    "build:vue": "pnpm --filter vue build",
    "storybook:vue": "pnpm --filter storybook-vue storybook",
    "build-storybook:vue": "pnpm --filter storybook-vue build-storybook",
    "build:angular": "pnpm --filter angular build",
    "storybook:angular": "pnpm --filter storybook-angular storybook",
    "build-storybook:angular": "pnpm --filter storybook-angular build-storybook",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "download"
    }
  },
  "type": "module"
}
